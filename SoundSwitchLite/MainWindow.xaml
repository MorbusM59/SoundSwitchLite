<Window x:Class="SoundSwitchLite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SoundSwitchLite"
        xmlns:converters="clr-namespace:SoundSwitchLite.Converters"
        Title="SoundSwitch Lite"
        MinWidth="520" MinHeight="200"
        Width="580" SizeToContent="Height" MaxHeight="470"
        Background="#1E1E2E"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Icon="/Assets/app.ico"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp">

    <Window.Resources>
        <converters:BoolToBrushConverter x:Key="ActiveBorderBrush"
            TrueBrush="#6C63FF"
            FalseBrush="#333346" />
        <converters:BoolToBrushConverter x:Key="ActiveButtonBrush"
            TrueBrush="#6C63FF"
            FalseBrush="#2A2A3E" />
        <converters:BoolToBrushConverter x:Key="ActiveForegroundBrush"
            TrueBrush="#FFFFFF"
            FalseBrush="#666680" />
        <converters:BoolToOpacityConverter x:Key="OpacityConverter"
            TrueOpacity="1.0"
            FalseOpacity="0.4" />

        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#3D3A5C"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#4A4870"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="BorderBrush" Value="#444460"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="false" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="28"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#E0E0F0"
                                                           Text="{Binding Path=SelectedItem.Name, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                                <TextBlock Grid.Column="1" Text="&#9662;" Foreground="#999BB5"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#2A2A3E" BorderBrush="#444460" BorderThickness="1"
                                        CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="#2A2A3E" CornerRadius="4" SnapsToDevicePixels="True">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder" Background="#555580" CornerRadius="4" Margin="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#6C63FF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#7D75FF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E2E" CornerRadius="12" BorderBrush="#2D2D40" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#16162A" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="&#128266;  SoundSwitch Lite"
                               Foreground="#E0E0F0" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <Button x:Name="CloseButton" Content="&#x2715;"
                            Width="32" Height="32" HorizontalAlignment="Right" Margin="0,0,8,0"
                            Foreground="#888899" BorderThickness="0" FontSize="13" Cursor="Hand"
                            Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Width="28" Height="28">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#CC3355"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="#888899"/>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12,16,0">
                <ItemsControl x:Name="DeviceSlotsControl" ItemsSource="{Binding DeviceSlots}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10" CornerRadius="12" Padding="12,10"
                                    Background="#25253A" BorderThickness="1.5"
                                    BorderBrush="{Binding IsActive, Converter={StaticResource ActiveBorderBrush}}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="36"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" Width="36" Height="36"
                                                Click="PlayButton_Click" Tag="{Binding}"
                                                Cursor="Hand" ToolTip="Set as default output device">
                                            <Button.Background>
                                                <Binding Path="IsActive" Converter="{StaticResource ActiveButtonBrush}"/>
                                            </Button.Background>
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="18" Width="36" Height="36">
                                                                    <TextBlock Text="&#9654;"
                                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                               Foreground="{Binding IsActive, Converter={StaticResource ActiveForegroundBrush}}"
                                                                               FontSize="13" Margin="2,0,0,0"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Opacity" Value="0.85"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <ComboBox Grid.Column="1" Margin="10,0,10,0"
                                                  Style="{StaticResource DarkComboBox}"
                                                  ItemsSource="{Binding AvailableDevices}"
                                                  SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                                                  DisplayMemberPath="Name"
                                                  SelectionChanged="DeviceComboBox_SelectionChanged"
                                                  Tag="{Binding}"/>

                                        <Border Grid.Column="2" Height="36" CornerRadius="8"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="HotkeyField_MouseLeftButtonDown"
                                                MouseRightButtonDown="HotkeyField_MouseRightButtonDown"
                                                Tag="{Binding}"
                                                ToolTip="Left-click to assign hotkey; right-click to clear">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#2A2A3E"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="BorderBrush" Value="#444460"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsListening}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#6C63FF"/>
                                                            <Setter Property="Background" Value="#2E2A4A"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding HotkeyDisplay}"
                                                       Foreground="#C0BFDB" FontSize="12"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Border>

                                        <Button Grid.Column="3" Width="28" Height="28" Margin="6,0,0,0"
                                                Click="RemoveSlot_Click" Tag="{Binding}"
                                                Cursor="Hand" ToolTip="Remove this slot">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="#666680"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Width="28" Height="28">
                                                                    <TextBlock Text="&#x2715;"
                                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                               Foreground="{TemplateBinding Foreground}" FontSize="12"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#3D2A3A"/>
                                                                        <Setter Property="Foreground" Value="#FF6680"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>

                                    <!-- Volume row -->
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding EnforceVolume, Mode=TwoWay}"
                                                  Checked="VolumeEnforce_Changed"
                                                  Unchecked="VolumeEnforce_Changed"
                                                  Foreground="#C0BFDB" FontSize="12"
                                                  VerticalAlignment="Center"
                                                  ToolTip="Enforce this volume when activating the device"
                                                  Content="Default volume:"/>

                                        <Grid Grid.Column="1" Margin="8,0,44,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider Grid.Column="0"
                                                    Minimum="0" Maximum="100"
                                                    Value="{Binding DefaultVolume, Mode=TwoWay}"
                                                    VerticalAlignment="Center"
                                                    IsEnabled="{Binding EnforceVolume}"
                                                    ValueChanged="VolumeSlider_ValueChanged"
                                                    ToolTip="{Binding DefaultVolume, StringFormat='{}{0}%'}">
                                                <Slider.Style>
                                                    <Style TargetType="Slider">
                                                        <Setter Property="Foreground" Value="#6C63FF"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Opacity" Value="0.4"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Slider.Style>
                                            </Slider>
                                            <TextBlock Grid.Column="1" Margin="8,0,0,0"
                                                       Text="{Binding DefaultVolume, StringFormat='{}{0}%'}"
                                                       Foreground="#C0BFDB" FontSize="12"
                                                       VerticalAlignment="Center" Width="36"
                                                       Opacity="{Binding EnforceVolume, Converter={StaticResource OpacityConverter}}"/>
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="2" Padding="16,8,16,16">
                <Button x:Name="AddDeviceButton" Content="+ Add Device"
                        Height="40" Click="AddDevice_Click"
                        HorizontalAlignment="Center" Padding="24,0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#6C63FF"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Visibility" Value="Visible"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#7D75FF"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#5A52D5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
