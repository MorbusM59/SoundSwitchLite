<Window x:Class="SoundSwitchLite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SoundSwitchLite"
        xmlns:converters="clr-namespace:SoundSwitchLite.Converters"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Title="SoundSwitch Lite"
        MinWidth="556" MinHeight="281"
        Width="556" SizeToContent="Height" MaxHeight="800"
        Background="#1E1E2E"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Icon="/Assets/app.ico"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        IsVisibleChanged="Window_IsVisibleChanged">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <converters:BoolToBrushConverter x:Key="ActiveBorderBrush"
            TrueBrush="#6C63FF" FalseBrush="#333346"/>
        <converters:BoolToBrushConverter x:Key="ActiveButtonBrush"
            TrueBrush="#6C63FF" FalseBrush="#2A2A3E"/>
        <converters:BoolToBrushConverter x:Key="ActiveForegroundBrush"
            TrueBrush="#FFFFFF" FalseBrush="#666680"/>
        <converters:BoolToBrushConverter x:Key="TabActiveBrush"
            TrueBrush="#6C63FF" FalseBrush="Transparent"/>
        <converters:BoolToBrushConverter x:Key="TabActiveFgBrush"
            TrueBrush="#FFFFFF" FalseBrush="#888899"/>
        <converters:CountToVisibilityConverter x:Key="CountToVisibility"/>

        <!-- Dark ComboBox item -->
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#3D3A5C"/>
                            </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#4A4870"/>
                                </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="BorderBrush" Value="#444460"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="false" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Margin="10,0,8,0" VerticalAlignment="Center" Foreground="#E0E0F0"
                                                           Text="{Binding Path=SelectedItem.Name, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="1" Text="&#9662;" Foreground="#999BB5"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Grid>
                                            
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#2A2A3E" BorderBrush="#444460" BorderThickness="1"
                                        CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="#2A2A3E" CornerRadius="4" SnapsToDevicePixels="True">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder" Background="#555580" CornerRadius="4" Margin="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#6C63FF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#7D75FF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Thin slider matching scrollbar thumb aesthetic -->
        <Style x:Key="ThinSlider" TargetType="Slider">
            <Setter Property="Height" Value="18" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Background="#2A2A3E" CornerRadius="6" Height="8" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineLeftCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineRightCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14" VerticalAlignment="Center">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder" Background="#555580" CornerRadius="7" Width="14" Height="14" VerticalAlignment="Center" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#6C63FF" />
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#7D75FF" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small icon button (volume +/-) -->
        <Style x:Key="SmallIconButton" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Foreground" Value="#C0BFDB"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#2A2A3E" CornerRadius="6"
                                Width="24" Height="24"
                                BorderBrush="#444460" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D3A5C"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6C63FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A4870"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slot-level icon button (match slot height) -->
        <Style x:Key="SlotIconButton" TargetType="Button" BasedOn="{StaticResource SmallIconButton}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Small info icon button -->
        <Style x:Key="InfoIconButton" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Foreground" Value="#C0BFDB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Width="22" Height="22">
                            <TextBlock Text="i" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A3E"/>
                                <Setter Property="Foreground" Value="#6C63FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action button (Add Device) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#6C63FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7D75FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#5A52D5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary action button (Send to unused) -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#C0BFDB"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444460"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3D3A5C"/>
                                <Setter Property="BorderBrush" Value="#6C63FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab button style -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Border Height="3" CornerRadius="2"
                                        Background="{TemplateBinding Foreground}"
                                        Opacity="0" x:Name="Indicator"
                                        Margin="20,0"/>
                                <ContentPresenter HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Global tooltip delay -->
        <Style TargetType="FrameworkElement">
            <Setter Property="ToolTipService.InitialShowDelay" Value="1000"/>
        </Style>

        <!-- Shared device slot DataTemplate -->
        <DataTemplate x:Key="DeviceSlotTemplate">
            <Border Margin="0,0,0,10" CornerRadius="12" Padding="20,10"
                    Background="#25253A" BorderThickness="1.5"
                    MouseLeftButtonDown="Card_MouseLeftButtonDown"
                    MouseRightButtonDown="Card_MouseRightButtonDown"
                    Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{Binding IsActive, Converter={StaticResource ActiveBorderBrush}}"/>
                        <Setter Property="Background" Value="#25253A"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsArmedForDeletion}" Value="True">
                                <Setter Property="BorderBrush" Value="#FF5566"/>
                                <Setter Property="Background" Value="#3A1A22"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="170"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="120"/>
                    </Grid.ColumnDefinitions>

                    <!-- Device selector -->
                    <ComboBox Grid.Column="0" Margin="0,0,20,0"
                              Style="{StaticResource DarkComboBox}"
                              ItemsSource="{Binding AvailableDevices}"
                              SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              SelectionChanged="DeviceComboBox_SelectionChanged"
                              Tag="{Binding}"
                              ToolTip="Select device. Right click for additional information."
                              MouseRightButtonDown="Element_MouseRightButtonDown"/>

                    <!-- Inline base volume controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,20,0">
                        <Button Content="&#8722;" Style="{StaticResource SlotIconButton}" Margin="0,0,5,0"
                                Click="VolumeDecrement_Click" Tag="{Binding}"
                                ToolTip="Decrease base volume. Right click for additional information."
                                PreviewMouseLeftButtonDown="VolumeButton_PreviewMouseDown"
                                PreviewMouseLeftButtonUp="VolumeButton_PreviewMouseUp"
                                MouseLeave="VolumeButton_MouseLeave"
                                MouseRightButtonDown="Element_MouseRightButtonDown"/>
                        <Border Width="64" Height="34" Background="#2A2A3E"
                                BorderBrush="#444460" BorderThickness="1" CornerRadius="6"
                                Margin="0,0,5,0">
                            <TextBox Text="{Binding BaseVolume, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Background="Transparent" Foreground="#E0E0F0"
                                     BorderThickness="0" TextAlignment="Center"
                                     VerticalAlignment="Center" VerticalContentAlignment="Center" FontSize="12"
                                     LostFocus="BaseVolumeTextBox_LostFocus"
                                     PreviewTextInput="NumberOnly_PreviewTextInput"
                                     DataObject.Pasting="NumberOnly_Pasting"
                                     Tag="Base volume value. Right click for additional information."
                                     ToolTip="Base volume. Right click for additional information."
                                     MouseRightButtonDown="Element_MouseRightButtonDown"/>
                        </Border>
                        <Button Content="+" Style="{StaticResource SlotIconButton}"
                                Click="VolumeIncrement_Click" Tag="{Binding}"
                                ToolTip="Increase base volume. Right click for additional information."
                                PreviewMouseLeftButtonDown="VolumeButton_PreviewMouseDown"
                                PreviewMouseLeftButtonUp="VolumeButton_PreviewMouseUp"
                                MouseLeave="VolumeButton_MouseLeave"
                                MouseRightButtonDown="Element_MouseRightButtonDown"/>
                    </StackPanel>

                    <!-- Hotkey field -->
                    <Border Grid.Column="2" Height="34" CornerRadius="8" Margin="0"
                            Cursor="Hand"
                            MouseLeftButtonDown="HotkeyField_MouseLeftButtonDown"
                            MouseRightButtonDown="HotkeyField_MouseRightButtonDown"
                            Tag="{Binding}"
                            ToolTip="Left-click to assign hotkey; right-click to clear">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#2A2A3E"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="#444460"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsListening}" Value="True">
                                        <Setter Property="BorderBrush" Value="#6C63FF"/>
                                        <Setter Property="Background" Value="#2E2A4A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding HotkeyDisplay}"
                                   Foreground="#C0BFDB" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Stretch"
                                   TextAlignment="Center" TextWrapping="NoWrap"
                                   Margin="8,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Border Background="#1E1E2E" CornerRadius="12" BorderBrush="#2D2D40" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>   <!-- title bar -->
                <RowDefinition Height="*"/>    <!-- tab content -->
                <RowDefinition Height="46"/>   <!-- tab bar -->
            </Grid.RowDefinitions>

            <!-- ── Title bar ─────────────────────────────────────── -->
            <Border Grid.Row="0" Background="#16162A" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="&#128266;  SoundSwitch Lite"
                               Foreground="#E0E0F0" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <Button x:Name="CloseButton"
                            Width="32" Height="32" HorizontalAlignment="Right" Margin="0,0,8,0"
                            Foreground="#888899" BorderThickness="0" FontSize="13" Cursor="Hand"
                            Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Width="28" Height="28">
                                                <fa:IconBlock Icon="Times" HorizontalAlignment="Center" VerticalAlignment="Center" Width="12" Height="12" Foreground="{TemplateBinding Foreground}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#CC3355"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="#888899"/>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Tab content area ──────────────────────────────── -->

            <!-- OUTPUT TAB -->
            <Grid Grid.Row="1"
                  Visibility="{Binding IsOutputTabSelected, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Master volume card -->
                <Border Grid.Row="0" Margin="14,10,14,0" Padding="14,8"
                    Background="#25253A" CornerRadius="12"
                    BorderBrush="#333346" BorderThickness="1.5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Master volume"
                                   Foreground="#C0BFDB" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Slider x:Name="MasterVolumeSlider" Grid.Column="1" Minimum="0" Maximum="100"
                                Value="{Binding MasterVolume, Mode=TwoWay}"
                                VerticalAlignment="Center"
                                ValueChanged="MasterVolumeSlider_ValueChanged"
                                PreviewMouseLeftButtonDown="VolumeSlider_PreviewMouseLeftButtonDown"
                                   MouseMove="VolumeSlider_MouseMove"
                                   PreviewMouseLeftButtonUp="VolumeSlider_PreviewMouseLeftButtonUp"
                                Style="{StaticResource ThinSlider}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding MasterVolume, StringFormat='{}{0}%'}"
                                   Foreground="#C0BFDB" FontSize="12"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Output device slots -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,8,14,0">
                    <ItemsControl ItemsSource="{Binding OutputSlots}"
                                  ItemTemplate="{StaticResource DeviceSlotTemplate}"/>
                </ScrollViewer>

                <!-- Footer buttons -->
                <Border Grid.Row="2" Padding="14,6,14,10"
                        Visibility="{Binding OutputFooterVisible, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="+ Add Device"
                            Style="{StaticResource PrimaryButton}"
                            Padding="18,0"
                            Click="AddOutputDevice_Click"
                            Tag="Add a new output slot. Right click for additional information."
                            ToolTip="Add a new output slot. Right click for additional information."
                            MouseRightButtonDown="Element_MouseRightButtonDown"
                            HorizontalAlignment="Stretch"
                            Visibility="{Binding CanAddOutputDevice, Converter={StaticResource BoolToVisibility}}"/>
                        <Button Grid.Column="2" Content="Send other devices to unused"
                            Style="{StaticResource SecondaryButton}"
                            Padding="14,0"
                            Click="SendOutputToUnused_Click"
                            Tag="Send other devices to unused. Right click for additional information."
                            ToolTip="Send other devices to unused. Right click for additional information."
                            MouseRightButtonDown="Element_MouseRightButtonDown"
                            HorizontalAlignment="Stretch"
                            Visibility="{Binding CanSendOutputDevices, Converter={StaticResource BoolToVisibility}}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- INPUT TAB -->
            <Grid Grid.Row="1"
                  Visibility="{Binding IsInputTabSelected, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Master volume card (same binding) -->
                <Border Grid.Row="0" Margin="14,10,14,0" Padding="14,8"
                    Background="#25253A" CornerRadius="12"
                    BorderBrush="#333346" BorderThickness="1.5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Master volume"
                                   Foreground="#C0BFDB" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Slider x:Name="InputMasterVolumeSlider" Grid.Column="1" Minimum="0" Maximum="100"
                                Value="{Binding InputMasterVolume, Mode=TwoWay}"
                                VerticalAlignment="Center"
                                ValueChanged="InputMasterVolumeSlider_ValueChanged"
                                PreviewMouseLeftButtonDown="VolumeSlider_PreviewMouseLeftButtonDown"
                                   MouseMove="VolumeSlider_MouseMove"
                                   PreviewMouseLeftButtonUp="VolumeSlider_PreviewMouseLeftButtonUp"
                                Style="{StaticResource ThinSlider}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding InputMasterVolume, StringFormat='{}{0}%'}"
                                   Foreground="#C0BFDB" FontSize="12"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Input device slots -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,8,14,0">
                    <ItemsControl ItemsSource="{Binding InputSlots}"
                                  ItemTemplate="{StaticResource DeviceSlotTemplate}"/>
                </ScrollViewer>

                <!-- Footer buttons (compact) -->
                <Border Grid.Row="2" Padding="14,6,14,10"
                        Visibility="{Binding InputFooterVisible, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="+ Add Device"
                            Style="{StaticResource PrimaryButton}"
                            Padding="18,0"
                            Click="AddInputDevice_Click"
                            Tag="Add a new input slot. Right click for additional information."
                            ToolTip="Add a new input slot. Right click for additional information."
                            MouseRightButtonDown="Element_MouseRightButtonDown"
                            HorizontalAlignment="Stretch"
                            Visibility="{Binding CanAddInputDevice, Converter={StaticResource BoolToVisibility}}"/>
                        <Button Grid.Column="2" Content="Send other devices to unused"
                            Style="{StaticResource SecondaryButton}"
                            Padding="14,0"
                            Click="SendInputToUnused_Click"
                            Tag="Send other devices to unused. Right click for additional information."
                            ToolTip="Send other devices to unused. Right click for additional information."
                            MouseRightButtonDown="Element_MouseRightButtonDown"
                            HorizontalAlignment="Stretch"
                            Visibility="{Binding CanSendInputDevices, Converter={StaticResource BoolToVisibility}}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- UNUSED DEVICES TAB -->
            <Grid Grid.Row="1"
                  Visibility="{Binding IsUnusedTabSelected, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10,14,10">
                    <StackPanel>
                        <!-- Empty state -->
                        <TextBlock Text="No unused devices"
                                   Foreground="#555580" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,20,0,0"
                                   Visibility="{Binding HasNoUnusedDevices, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Unused output devices section -->
                        <StackPanel Visibility="{Binding UnusedOutputCount, Converter={StaticResource CountToVisibility}}">
                            <TextBlock Text="OUTPUT DEVICES"
                                       Foreground="#6C63FF" FontSize="10" FontWeight="SemiBold"
                                       Margin="4,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding UnusedOutputDevices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" CornerRadius="10" Padding="12,10"
                                            Background="#25253A" BorderThickness="1" BorderBrush="#333346"
                                            Cursor="Hand" Tag="{Binding}"
                                            MouseLeftButtonDown="RestoreOutputDevice_Click"
                                            ToolTip="Restore device. Right click for additional information."
                                            MouseRightButtonDown="Element_MouseRightButtonDown">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                           Foreground="#E0E0F0" FontSize="13"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                                    Width="68" Height="26" Padding="6,0"
                                                    Click="RestoreOutputDevice_ButtonClick"
                                                    Tag="{Binding}"
                                                    ToolTip="Restore device. Right click for additional information."
                                                    MouseRightButtonDown="Element_MouseRightButtonDown">
                                                    <fa:IconBlock Icon="Undo" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#6C63FF" Width="14" Height="14" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Spacer between sections -->
                        <Border Height="8"
                                Visibility="{Binding UnusedOutputCount, Converter={StaticResource CountToVisibility}}"/>

                        <!-- Unused input devices section -->
                        <StackPanel Visibility="{Binding UnusedInputCount, Converter={StaticResource CountToVisibility}}">
                            <TextBlock Text="INPUT DEVICES"
                                       Foreground="#6C63FF" FontSize="10" FontWeight="SemiBold"
                                       Margin="4,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding UnusedInputDevices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" CornerRadius="10" Padding="12,10"
                                            Background="#25253A" BorderThickness="1" BorderBrush="#333346"
                                            Cursor="Hand" Tag="{Binding}"
                                            MouseLeftButtonDown="RestoreInputDevice_Click"
                                            ToolTip="Restore device. Right click for additional information."
                                            MouseRightButtonDown="Element_MouseRightButtonDown">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                           Foreground="#E0E0F0" FontSize="13"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                                    Width="68" Height="26" Padding="6,0"
                                                    Click="RestoreInputDevice_ButtonClick"
                                                    Tag="{Binding}"
                                                    ToolTip="Restore device. Right click for additional information."
                                                    MouseRightButtonDown="Element_MouseRightButtonDown">
                                                    <fa:IconBlock Icon="Undo" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#6C63FF" Width="14" Height="14" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ── Info tab content (replaces the old collapsible info panel) -->
            <Grid Grid.Row="1" Visibility="{Binding IsInfoTabSelected, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10,14,10">
                    <StackPanel>
                            <TextBlock Text="Overview" Foreground="#6C63FF" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Text="SoundSwitch Lite is a minimal tray-first utility for quickly switching audio devices and assigning global hotkeys." Foreground="#C0BFDB" TextWrapping="Wrap" Margin="0,0,0,12"/>

                            <TextBlock Text="Features" Foreground="#6C63FF" FontSize="13" FontWeight="SemiBold" Margin="0,6,0,4"/>
                            <TextBlock Foreground="#C0BFDB" TextWrapping="Wrap" Margin="0,0,0,12">
                                • System tray operation and single-instance behavior
                            </TextBlock>
                            <TextBlock Foreground="#C0BFDB" TextWrapping="Wrap" Margin="0,0,0,12">
                                • Assign global hotkeys to device slots for one-press switching
                            </TextBlock>
                            <TextBlock Foreground="#C0BFDB" TextWrapping="Wrap" Margin="0,0,0,12">
                                • Per-slot base-volume override and master volume control
                            </TextBlock>

                            <Separator Margin="0,8,0,8"/>

                            <TextBlock Text="Quick Start" Foreground="#6C63FF" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Foreground="#C0BFDB" TextWrapping="Wrap" Margin="0,0,0,6">1. Click &quot;+ Add Device&quot; to create a slot.</TextBlock>
                            <TextBlock Foreground="#C0BFDB" TextWrapping="Wrap" Margin="0,0,0,6">2. Use the dropdown to select a system device for the slot. Click the card to activate that device.</TextBlock>
                            <TextBlock Foreground="#C0BFDB" TextWrapping="Wrap" Margin="0,0,0,6">3. Click the hotkey field and press the desired key combination to assign a global shortcut.</TextBlock>
                            <TextBlock Foreground="#C0BFDB" TextWrapping="Wrap" Margin="0,0,0,12">4. To remove a slot: right-click an inactive card to arm it for deletion; right-click again to confirm removal.</TextBlock>

                            <Separator Margin="0,8,0,8"/>

                            <TextBlock Text="Hotkeys" Foreground="#6C63FF" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Foreground="#C0BFDB" TextWrapping="Wrap" Margin="0,0,0,12">Hotkeys are global. Assign with the hotkey field; clear by right-clicking the field. Careful to avoid conflicting system shortcuts.</TextBlock>

                            <TextBlock Text="Settings &amp; Persistence" Foreground="#6C63FF" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Foreground="#C0BFDB" TextWrapping="Wrap" Margin="0,0,0,6">All mappings and hotkeys are stored in your AppData folder:</TextBlock>
                            <TextBlock Foreground="#C0BFDB" TextWrapping="Wrap" Margin="0,0,0,12">%AppData%\SoundSwitchLite\settings.json</TextBlock>

                            <Separator Margin="0,8,0,8"/>

                            <TextBlock Text="Unused Devices" Foreground="#6C63FF" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Foreground="#C0BFDB" TextWrapping="Wrap" Margin="0,0,0,12">Devices you send to &quot;Unused&quot; are removed from the slot list and can be restored from the Unused tab.</TextBlock>

                            <Separator Margin="0,8,0,8"/>

                            <TextBlock Text="Troubleshooting" Foreground="#6C63FF" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Foreground="#C0BFDB" TextWrapping="Wrap" Margin="0,0,0,6">• If the app cannot change devices, ensure you have appropriate audio drivers and that another application is not exclusively using the device.</TextBlock>
                            <TextBlock Foreground="#C0BFDB" TextWrapping="Wrap" Margin="0,0,0,6">• You may see package compatibility warnings for the AudioSwitcher libraries; the app attempts to initialize audio safely and will continue running with degraded functionality if required.</TextBlock>
                            <TextBlock Foreground="#C0BFDB" TextWrapping="Wrap" Margin="0,0,0,12">• If XAML-generated files are missing after editing, try cleaning the project (`dotnet clean`) and rebuilding to regenerate BAML/.g.cs artifacts.</TextBlock>

                            <Separator Margin="0,8,0,8"/>

                            <TextBlock Text="License" Foreground="#6C63FF" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Foreground="#C0BFDB" TextWrapping="Wrap">SoundSwitch Lite is provided under the MIT License. See the repository README for details.</TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ── Tab bar ───────────────────────────────────────── -->
                <Border Grid.Row="2" Background="#16162A" CornerRadius="0,0,12,12"
                    BorderBrush="#2D2D40" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                        Content="&#128266; Output"
                        Style="{StaticResource TabButton}"
                        Background="{Binding IsOutputTabSelected, Converter={StaticResource TabActiveBrush}}"
                        Foreground="{Binding IsOutputTabSelected, Converter={StaticResource TabActiveFgBrush}}"
                        Click="TabOutput_Click"/>

                    <Button Grid.Column="1"
                        Content="&#127908; Input"
                        Style="{StaticResource TabButton}"
                        Background="{Binding IsInputTabSelected, Converter={StaticResource TabActiveBrush}}"
                        Foreground="{Binding IsInputTabSelected, Converter={StaticResource TabActiveFgBrush}}"
                        Click="TabInput_Click"/>

                    <Button Grid.Column="2"
                        Content="&#128230; Unused"
                        Style="{StaticResource TabButton}"
                        Background="{Binding IsUnusedTabSelected, Converter={StaticResource TabActiveBrush}}"
                        Foreground="{Binding IsUnusedTabSelected, Converter={StaticResource TabActiveFgBrush}}"
                        Click="TabUnused_Click"/>

                    <Button Grid.Column="3"
                        Style="{StaticResource TabButton}"
                        Background="{Binding IsInfoTabSelected, Converter={StaticResource TabActiveBrush}}"
                        Foreground="{Binding IsInfoTabSelected, Converter={StaticResource TabActiveFgBrush}}"
                        Click="TabInfo_Click">
                    <fa:IconBlock Icon="InfoCircle" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
