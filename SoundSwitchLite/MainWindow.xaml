<Window x:Class="SoundSwitchLite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
        xmlns:local="clr-namespace:SoundSwitchLite"
        xmlns:converters="clr-namespace:SoundSwitchLite.Converters"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Title="SoundSwitch Lite"
        MinWidth="556" MinHeight="281"
        Width="556" SizeToContent="Height" MaxHeight="800"
        Background="{DynamicResource ColorAppBackground}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Icon="/Assets/app.ico"
        PreviewMouseDown="Window_PreviewMouseDown"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        IsVisibleChanged="Window_IsVisibleChanged">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Visual tokens -->
        <SolidColorBrush x:Key="ColorAccent" Color="#6C63FF" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorAccentHover" Color="#7D75FF" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorAccentPressed" Color="#5A52D5" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorTabActiveBackground" Color="#6C63FF" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorTabActiveForeground" Color="#E0E0F0" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorAppBackground" Color="#1E1E2E" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorTitlebarBackground" Color="#16162A" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorWindowBorder" Color="#2D2D40" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorCardBackground" Color="#25253A" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorControlBackground" Color="#2A2A3E" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorControlHoverBackground" Color="#3D3A5C" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorControlPressedBackground" Color="#4A4870" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorControlListeningBackground" Color="#2E2A4A" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorBorderSubtle" Color="#333346" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorBorderDefault" Color="#444460" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorSliderTrack" Color="#2A2A3E" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorSliderThumb" Color="#555580" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorTextPrimary" Color="#E0E0F0" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorTextSecondary" Color="#C0BFDB" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorTextMuted" Color="#888899" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorTextDim" Color="#666680" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorDangerBorder" Color="#FF5566" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorDangerBackground" Color="#3A1A22" po:Freeze="False"/>
        <SolidColorBrush x:Key="ColorCloseHover" Color="#CC3355" po:Freeze="False"/>

        <CornerRadius x:Key="RadiusWindow">12</CornerRadius>
        <CornerRadius x:Key="RadiusTitlebar">12,12,0,0</CornerRadius>
        <CornerRadius x:Key="RadiusTabbar">0,0,12,12</CornerRadius>
        <CornerRadius x:Key="RadiusCard">12</CornerRadius>
        <CornerRadius x:Key="RadiusControl">8</CornerRadius>
        <CornerRadius x:Key="RadiusMini">6</CornerRadius>

        <Thickness x:Key="BorderThin">1</Thickness>
        <Thickness x:Key="BorderCard">1.5</Thickness>
        <Thickness x:Key="BorderTabbar">0,1,0,0</Thickness>

        <converters:BoolToBrushConverter x:Key="ActiveBorderBrush"
            TrueBrush="{StaticResource ColorAccent}" FalseBrush="{StaticResource ColorBorderSubtle}"/>
        <converters:BoolToBrushConverter x:Key="ActiveButtonBrush"
            TrueBrush="{StaticResource ColorAccent}" FalseBrush="{StaticResource ColorControlBackground}"/>
        <converters:BoolToBrushConverter x:Key="ActiveForegroundBrush"
            TrueBrush="{StaticResource ColorTextPrimary}" FalseBrush="{StaticResource ColorTextDim}"/>
        <converters:BoolToBrushConverter x:Key="TabActiveBrush"
            TrueBrush="{StaticResource ColorTabActiveBackground}" FalseBrush="Transparent"/>
        <converters:BoolToBrushConverter x:Key="TabActiveFgBrush"
            TrueBrush="{StaticResource ColorTabActiveForeground}" FalseBrush="{StaticResource ColorTextMuted}"/>
        <converters:CountToVisibilityConverter x:Key="CountToVisibility"/>

        <!-- Info tab typography tokens -->
        <Style x:Key="InfoHeadlineText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ColorAccent}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="InfoBodyText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ColorTextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="InfoSectionSeparator" TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource ColorBorderSubtle}"/>
        </Style>

        <Style x:Key="TitlebarGlyphButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorTextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Width="28" Height="28">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ColorControlHoverBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox item -->
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource ColorControlBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorTextPrimary}"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ColorControlHoverBackground}"/>
                            </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ColorControlPressedBackground}"/>
                                </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ColorControlBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ColorBorderDefault}"/>
            <Setter Property="BorderThickness" Value="{StaticResource BorderThin}"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="false" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="{StaticResource RadiusControl}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Margin="10,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource ColorTextPrimary}"
                                                           Text="{Binding Path=SelectedItem.Name, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="1" Text="&#9662;" Foreground="{DynamicResource ColorTextMuted}"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Grid>
                                            
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="{DynamicResource ColorControlBackground}" BorderBrush="{DynamicResource ColorBorderDefault}" BorderThickness="{StaticResource BorderThin}"
                                    CornerRadius="{StaticResource RadiusControl}" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{DynamicResource ColorControlBackground}" CornerRadius="4" SnapsToDevicePixels="True">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder" Background="{DynamicResource ColorSliderThumb}" CornerRadius="4" Margin="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ColorAccent}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ColorAccentHover}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Thin slider matching scrollbar thumb aesthetic -->
        <Style x:Key="ThinSlider" TargetType="Slider">
            <Setter Property="Height" Value="18" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Background="{DynamicResource ColorSliderTrack}" CornerRadius="{StaticResource RadiusMini}" Height="8" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineLeftCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineRightCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14" VerticalAlignment="Center">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder" Background="{DynamicResource ColorSliderThumb}" CornerRadius="7" Width="14" Height="14" VerticalAlignment="Center" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ColorAccent}" />
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ColorAccentHover}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small icon button (volume +/-) -->
        <Style x:Key="SmallIconButton" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorTextSecondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource ColorControlBackground}" CornerRadius="{StaticResource RadiusMini}"
                                Width="24" Height="24"
                            BorderBrush="{DynamicResource ColorBorderDefault}" BorderThickness="{StaticResource BorderThin}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ColorControlHoverBackground}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ColorAccent}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ColorControlPressedBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slot-level icon button (match slot height) -->
        <Style x:Key="SlotIconButton" TargetType="Button" BasedOn="{StaticResource SmallIconButton}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Small info icon button -->
        <Style x:Key="InfoIconButton" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Foreground" Value="#C0BFDB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Width="22" Height="22">
                            <TextBlock Text="i" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A3E"/>
                                <Setter Property="Foreground" Value="#6C63FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action button (Add Device) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ColorAccent}"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorTextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ColorAccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ColorAccentPressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary action button (Send to unused) -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ColorControlBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorTextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="{StaticResource BorderThin}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ColorBorderDefault}"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusControl}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ColorControlHoverBackground}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource ColorAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab button style -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Border Height="3" CornerRadius="2"
                                        Background="{TemplateBinding Foreground}"
                                        Opacity="0" x:Name="Indicator"
                                        Margin="20,0"/>
                                <ContentPresenter HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Global tooltip delay -->
        <Style TargetType="FrameworkElement">
            <Setter Property="ToolTipService.InitialShowDelay" Value="1000"/>
        </Style>

        <!-- Shared device slot DataTemplate -->
        <DataTemplate x:Key="DeviceSlotTemplate">
                <Border Margin="0,0,0,10" CornerRadius="{StaticResource RadiusCard}" Padding="20,10"
                    Background="{DynamicResource ColorCardBackground}" BorderThickness="{StaticResource BorderCard}"
                    MouseLeftButtonDown="Card_MouseLeftButtonDown"
                    MouseRightButtonDown="Card_MouseRightButtonDown"
                    Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{Binding IsActive, Converter={StaticResource ActiveBorderBrush}}"/>
                        <Setter Property="Background" Value="{DynamicResource ColorCardBackground}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsArmedForDeletion}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource ColorDangerBorder}"/>
                                <Setter Property="Background" Value="{DynamicResource ColorDangerBackground}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="170"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="120"/>
                    </Grid.ColumnDefinitions>

                    <!-- Device selector -->
                    <ComboBox Grid.Column="0" Margin="0,0,20,0"
                              Style="{StaticResource DarkComboBox}"
                              ItemsSource="{Binding AvailableDevices}"
                              SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              SelectionChanged="DeviceComboBox_SelectionChanged"
                              Tag="{Binding}"
                              ToolTip="Select device. Right click for additional information."
                              MouseRightButtonDown="Element_MouseRightButtonDown"/>

                    <!-- Inline base volume controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,20,0">
                        <Button Content="&#8722;" Style="{StaticResource SlotIconButton}" Margin="0,0,5,0"
                                Click="VolumeDecrement_Click" Tag="{Binding}"
                                ToolTip="Decrease base volume. Right click for additional information."
                                PreviewMouseLeftButtonDown="VolumeButton_PreviewMouseDown"
                                PreviewMouseLeftButtonUp="VolumeButton_PreviewMouseUp"
                                MouseLeave="VolumeButton_MouseLeave"
                                MouseRightButtonDown="Element_MouseRightButtonDown"/>
                        <Border Width="64" Height="34" Background="{DynamicResource ColorControlBackground}"
                            BorderBrush="{DynamicResource ColorBorderDefault}" BorderThickness="{StaticResource BorderThin}" CornerRadius="{StaticResource RadiusMini}"
                                Margin="0,0,5,0">
                            <TextBox Text="{Binding BaseVolume, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                 Background="Transparent" Foreground="{DynamicResource ColorTextPrimary}"
                                     BorderThickness="0" TextAlignment="Center"
                                     VerticalAlignment="Center" VerticalContentAlignment="Center" FontSize="12"
                                     LostFocus="BaseVolumeTextBox_LostFocus"
                                     PreviewTextInput="NumberOnly_PreviewTextInput"
                                     DataObject.Pasting="NumberOnly_Pasting"
                                     Tag="Base volume value. Right click for additional information."
                                     ToolTip="Base volume. Right click for additional information."
                                     MouseRightButtonDown="Element_MouseRightButtonDown"/>
                        </Border>
                        <Button Content="+" Style="{StaticResource SlotIconButton}"
                                Click="VolumeIncrement_Click" Tag="{Binding}"
                                ToolTip="Increase base volume. Right click for additional information."
                                PreviewMouseLeftButtonDown="VolumeButton_PreviewMouseDown"
                                PreviewMouseLeftButtonUp="VolumeButton_PreviewMouseUp"
                                MouseLeave="VolumeButton_MouseLeave"
                                MouseRightButtonDown="Element_MouseRightButtonDown"/>
                    </StackPanel>

                    <!-- Hotkey field -->
                        <Border Grid.Column="2" Height="34" CornerRadius="{StaticResource RadiusControl}" Margin="0"
                            Cursor="Hand"
                            MouseLeftButtonDown="HotkeyField_MouseLeftButtonDown"
                            MouseRightButtonDown="HotkeyField_MouseRightButtonDown"
                            Tag="{Binding}"
                            ToolTip="Left-click to assign hotkey; right-click to clear">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource ColorControlBackground}"/>
                                <Setter Property="BorderThickness" Value="{StaticResource BorderThin}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource ColorBorderDefault}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsListening}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource ColorAccent}"/>
                                        <Setter Property="Background" Value="{DynamicResource ColorControlListeningBackground}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding HotkeyDisplay}"
                                   Foreground="{DynamicResource ColorTextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Stretch"
                                   TextAlignment="Center" TextWrapping="NoWrap"
                                   Margin="8,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Border Background="{DynamicResource ColorAppBackground}" CornerRadius="{StaticResource RadiusWindow}" BorderBrush="{DynamicResource ColorWindowBorder}" BorderThickness="{StaticResource BorderThin}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>   <!-- title bar -->
                <RowDefinition Height="*"/>    <!-- tab content -->
                <RowDefinition Height="46"/>   <!-- tab bar -->
            </Grid.RowDefinitions>

            <!-- ── Title bar ─────────────────────────────────────── -->
            <Border Grid.Row="0" Background="{DynamicResource ColorTitlebarBackground}" CornerRadius="{StaticResource RadiusTitlebar}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="&#128266;  SoundSwitch Lite"
                               Foreground="{DynamicResource ColorTextPrimary}" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>

                    <Button x:Name="ThemeToggleButton"
                            Style="{StaticResource TitlebarGlyphButton}"
                            HorizontalAlignment="Right" Margin="0,0,72,0"
                            Click="ThemeToggleButton_Click"
                            ToolTip="Theme: System">
                        <fa:IconBlock x:Name="ThemeToggleIcon" Icon="Desktop" Width="12" Height="12"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>

                    <Button x:Name="MinimizeButton"
                            Style="{StaticResource TitlebarGlyphButton}"
                            HorizontalAlignment="Right" Margin="0,0,40,0"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimize">
                        <fa:IconBlock Icon="Minus" Width="12" Height="12"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>

                    <Button x:Name="CloseButton"
                            HorizontalAlignment="Right" Margin="0,0,8,0"
                            Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TitlebarGlyphButton}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Width="28" Height="28">
                                                <fa:IconBlock Icon="Times" HorizontalAlignment="Center" VerticalAlignment="Center" Width="12" Height="12" Foreground="{TemplateBinding Foreground}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ColorCloseHover}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Tab content area ──────────────────────────────── -->

            <!-- OUTPUT TAB -->
            <Grid Grid.Row="1"
                  Visibility="{Binding IsOutputTabSelected, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Master volume card -->
                <Border Grid.Row="0" Margin="14,10,14,0" Padding="14,8"
                    Background="{DynamicResource ColorCardBackground}" CornerRadius="{StaticResource RadiusCard}"
                    BorderBrush="{DynamicResource ColorBorderSubtle}" BorderThickness="{StaticResource BorderCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Master volume"
                                   Foreground="{DynamicResource ColorTextSecondary}" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Slider x:Name="MasterVolumeSlider" Grid.Column="1" Minimum="0" Maximum="100"
                                Value="{Binding MasterVolume, Mode=TwoWay}"
                                VerticalAlignment="Center"
                                ValueChanged="MasterVolumeSlider_ValueChanged"
                                PreviewMouseLeftButtonDown="VolumeSlider_PreviewMouseLeftButtonDown"
                                   MouseMove="VolumeSlider_MouseMove"
                                   PreviewMouseLeftButtonUp="VolumeSlider_PreviewMouseLeftButtonUp"
                                Style="{StaticResource ThinSlider}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding MasterVolume, StringFormat='{}{0}%'}"
                                   Foreground="{DynamicResource ColorTextSecondary}" FontSize="12"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Output device slots -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,8,14,0">
                    <ItemsControl ItemsSource="{Binding OutputSlots}"
                                  ItemTemplate="{StaticResource DeviceSlotTemplate}"/>
                </ScrollViewer>

                <!-- Footer buttons -->
                <Border Grid.Row="2" Padding="14,6,14,10"
                        Visibility="{Binding OutputFooterVisible, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="+ Add Device"
                            Style="{StaticResource PrimaryButton}"
                            Padding="18,0"
                            Click="AddOutputDevice_Click"
                            Tag="Add a new output slot. Right click for additional information."
                            ToolTip="Add a new output slot. Right click for additional information."
                            MouseRightButtonDown="Element_MouseRightButtonDown"
                            HorizontalAlignment="Stretch"
                            Visibility="{Binding CanAddOutputDevice, Converter={StaticResource BoolToVisibility}}"/>
                        <Button Grid.Column="2" Content="Send other devices to unused"
                            Style="{StaticResource SecondaryButton}"
                            Padding="14,0"
                            Click="SendOutputToUnused_Click"
                            Tag="Send other devices to unused. Right click for additional information."
                            ToolTip="Send other devices to unused. Right click for additional information."
                            MouseRightButtonDown="Element_MouseRightButtonDown"
                            HorizontalAlignment="Stretch"
                            Visibility="{Binding CanSendOutputDevices, Converter={StaticResource BoolToVisibility}}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- INPUT TAB -->
            <Grid Grid.Row="1"
                  Visibility="{Binding IsInputTabSelected, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Master volume card (same binding) -->
                <Border Grid.Row="0" Margin="14,10,14,0" Padding="14,8"
                    Background="{DynamicResource ColorCardBackground}" CornerRadius="{StaticResource RadiusCard}"
                    BorderBrush="{DynamicResource ColorBorderSubtle}" BorderThickness="{StaticResource BorderCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Master volume"
                                   Foreground="{DynamicResource ColorTextSecondary}" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Slider x:Name="InputMasterVolumeSlider" Grid.Column="1" Minimum="0" Maximum="100"
                                Value="{Binding InputMasterVolume, Mode=TwoWay}"
                                VerticalAlignment="Center"
                                ValueChanged="InputMasterVolumeSlider_ValueChanged"
                                PreviewMouseLeftButtonDown="VolumeSlider_PreviewMouseLeftButtonDown"
                                   MouseMove="VolumeSlider_MouseMove"
                                   PreviewMouseLeftButtonUp="VolumeSlider_PreviewMouseLeftButtonUp"
                                Style="{StaticResource ThinSlider}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding InputMasterVolume, StringFormat='{}{0}%'}"
                                   Foreground="{DynamicResource ColorTextSecondary}" FontSize="12"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Input device slots -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,8,14,0">
                    <ItemsControl ItemsSource="{Binding InputSlots}"
                                  ItemTemplate="{StaticResource DeviceSlotTemplate}"/>
                </ScrollViewer>

                <!-- Footer buttons (compact) -->
                <Border Grid.Row="2" Padding="14,6,14,10"
                        Visibility="{Binding InputFooterVisible, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="+ Add Device"
                            Style="{StaticResource PrimaryButton}"
                            Padding="18,0"
                            Click="AddInputDevice_Click"
                            Tag="Add a new input slot. Right click for additional information."
                            ToolTip="Add a new input slot. Right click for additional information."
                            MouseRightButtonDown="Element_MouseRightButtonDown"
                            HorizontalAlignment="Stretch"
                            Visibility="{Binding CanAddInputDevice, Converter={StaticResource BoolToVisibility}}"/>
                        <Button Grid.Column="2" Content="Send other devices to unused"
                            Style="{StaticResource SecondaryButton}"
                            Padding="14,0"
                            Click="SendInputToUnused_Click"
                            Tag="Send other devices to unused. Right click for additional information."
                            ToolTip="Send other devices to unused. Right click for additional information."
                            MouseRightButtonDown="Element_MouseRightButtonDown"
                            HorizontalAlignment="Stretch"
                            Visibility="{Binding CanSendInputDevices, Converter={StaticResource BoolToVisibility}}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- UNUSED DEVICES TAB -->
            <Grid Grid.Row="1"
                  Visibility="{Binding IsUnusedTabSelected, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10,14,10">
                    <StackPanel>
                        <!-- Empty state -->
                        <TextBlock Text="No unused devices"
                                   Foreground="{DynamicResource ColorSliderThumb}" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,20,0,0"
                                   Visibility="{Binding HasNoUnusedDevices, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Unused output devices section -->
                        <StackPanel Visibility="{Binding UnusedOutputCount, Converter={StaticResource CountToVisibility}}">
                            <TextBlock Text="OUTPUT DEVICES"
                                       Foreground="{DynamicResource ColorAccent}" FontSize="10" FontWeight="SemiBold"
                                       Margin="4,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding UnusedOutputDevices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" CornerRadius="10" Padding="12,10"
                                            Background="{DynamicResource ColorCardBackground}" BorderThickness="{StaticResource BorderThin}" BorderBrush="{DynamicResource ColorBorderSubtle}"
                                            Cursor="Hand" Tag="{Binding}"
                                            MouseLeftButtonDown="RestoreOutputDevice_Click"
                                            ToolTip="Restore device. Right click for additional information."
                                            MouseRightButtonDown="Element_MouseRightButtonDown">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                           Foreground="{DynamicResource ColorTextPrimary}" FontSize="13"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                                    Width="68" Height="26" Padding="6,0"
                                                    Click="RestoreOutputDevice_ButtonClick"
                                                    Tag="{Binding}"
                                                    ToolTip="Restore device. Right click for additional information."
                                                    MouseRightButtonDown="Element_MouseRightButtonDown">
                                                    <fa:IconBlock Icon="Undo" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource ColorAccent}" Width="14" Height="14" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Spacer between sections -->
                        <Border Height="8"
                                Visibility="{Binding UnusedOutputCount, Converter={StaticResource CountToVisibility}}"/>

                        <!-- Unused input devices section -->
                        <StackPanel Visibility="{Binding UnusedInputCount, Converter={StaticResource CountToVisibility}}">
                            <TextBlock Text="INPUT DEVICES"
                                       Foreground="{DynamicResource ColorAccent}" FontSize="10" FontWeight="SemiBold"
                                       Margin="4,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding UnusedInputDevices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" CornerRadius="10" Padding="12,10"
                                            Background="{DynamicResource ColorCardBackground}" BorderThickness="{StaticResource BorderThin}" BorderBrush="{DynamicResource ColorBorderSubtle}"
                                            Cursor="Hand" Tag="{Binding}"
                                            MouseLeftButtonDown="RestoreInputDevice_Click"
                                            ToolTip="Restore device. Right click for additional information."
                                            MouseRightButtonDown="Element_MouseRightButtonDown">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                           Foreground="{DynamicResource ColorTextPrimary}" FontSize="13"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                                    Width="68" Height="26" Padding="6,0"
                                                    Click="RestoreInputDevice_ButtonClick"
                                                    Tag="{Binding}"
                                                    ToolTip="Restore device. Right click for additional information."
                                                    MouseRightButtonDown="Element_MouseRightButtonDown">
                                                    <fa:IconBlock Icon="Undo" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource ColorAccent}" Width="14" Height="14" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ── Info tab content (replaces the old collapsible info panel) -->
            <Grid Grid.Row="1" Visibility="{Binding IsInfoTabSelected, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10,14,10">
                    <StackPanel>
                            <TextBlock Text="Overview" Style="{StaticResource InfoHeadlineText}" Margin="0,0,0,8"/>
                            <TextBlock Text="SoundSwitch Lite is a minimal tray-first utility for quickly switching audio devices and assigning global hotkeys." Style="{StaticResource InfoBodyText}" Margin="0,0,0,12"/>

                            <TextBlock Text="Features" Style="{StaticResource InfoHeadlineText}" Margin="0,6,0,4"/>
                            <TextBlock Style="{StaticResource InfoBodyText}" Margin="0,0,0,12">
                                • System tray operation and single-instance behavior
                            </TextBlock>
                            <TextBlock Style="{StaticResource InfoBodyText}" Margin="0,0,0,12">
                                • Assign global hotkeys to device slots for one-press switching
                            </TextBlock>
                            <TextBlock Style="{StaticResource InfoBodyText}" Margin="0,0,0,12">
                                • Per-slot base-volume override and master volume control
                            </TextBlock>

                            <Separator Style="{StaticResource InfoSectionSeparator}" Margin="0,8,0,8"/>

                            <TextBlock Text="Quick Start" Style="{StaticResource InfoHeadlineText}" Margin="0,0,0,8"/>
                            <TextBlock Style="{StaticResource InfoBodyText}" Margin="0,0,0,6">1. Click &quot;+ Add Device&quot; to create a slot.</TextBlock>
                            <TextBlock Style="{StaticResource InfoBodyText}" Margin="0,0,0,6">2. Use the dropdown to select a system device for the slot. Click the card to activate that device.</TextBlock>
                            <TextBlock Style="{StaticResource InfoBodyText}" Margin="0,0,0,6">3. Click the hotkey field and press the desired key combination to assign a global shortcut.</TextBlock>
                            <TextBlock Style="{StaticResource InfoBodyText}" Margin="0,0,0,12">4. To remove a slot: right-click an inactive card to arm it for deletion; right-click again to confirm removal.</TextBlock>

                            <Separator Style="{StaticResource InfoSectionSeparator}" Margin="0,8,0,8"/>

                            <TextBlock Text="Hotkeys" Style="{StaticResource InfoHeadlineText}" Margin="0,0,0,8"/>
                            <TextBlock Style="{StaticResource InfoBodyText}" Margin="0,0,0,12">Hotkeys are global. Assign with the hotkey field; clear by right-clicking the field. Careful to avoid conflicting system shortcuts.</TextBlock>

                            <TextBlock Text="Settings &amp; Persistence" Style="{StaticResource InfoHeadlineText}" Margin="0,0,0,8"/>
                            <TextBlock Style="{StaticResource InfoBodyText}" Margin="0,0,0,6">All mappings and hotkeys are stored in your AppData folder:</TextBlock>
                            <TextBlock Style="{StaticResource InfoBodyText}" Margin="0,0,0,12">%AppData%\SoundSwitchLite\settings.json</TextBlock>

                            <Separator Style="{StaticResource InfoSectionSeparator}" Margin="0,8,0,8"/>

                            <TextBlock Text="Unused Devices" Style="{StaticResource InfoHeadlineText}" Margin="0,0,0,8"/>
                            <TextBlock Style="{StaticResource InfoBodyText}" Margin="0,0,0,12">Devices you send to &quot;Unused&quot; are removed from the slot list and can be restored from the Unused tab.</TextBlock>

                            <Separator Style="{StaticResource InfoSectionSeparator}" Margin="0,8,0,8"/>

                            <TextBlock Text="Troubleshooting" Style="{StaticResource InfoHeadlineText}" Margin="0,0,0,8"/>
                            <TextBlock Style="{StaticResource InfoBodyText}" Margin="0,0,0,6">• If the app cannot change devices, ensure you have appropriate audio drivers and that another application is not exclusively using the device.</TextBlock>
                            <TextBlock Style="{StaticResource InfoBodyText}" Margin="0,0,0,6">• You may see package compatibility warnings for the AudioSwitcher libraries; the app attempts to initialize audio safely and will continue running with degraded functionality if required.</TextBlock>
                            <TextBlock Style="{StaticResource InfoBodyText}" Margin="0,0,0,12">• If XAML-generated files are missing after editing, try cleaning the project (`dotnet clean`) and rebuilding to regenerate BAML/.g.cs artifacts.</TextBlock>

                            <Separator Style="{StaticResource InfoSectionSeparator}" Margin="0,8,0,8"/>

                            <TextBlock Text="License" Style="{StaticResource InfoHeadlineText}" Margin="0,0,0,8"/>
                            <TextBlock Style="{StaticResource InfoBodyText}">SoundSwitch Lite is provided under the MIT License. See the repository README for details.</TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ── Tab bar ───────────────────────────────────────── -->
                <Border Grid.Row="2" Background="{DynamicResource ColorTitlebarBackground}" CornerRadius="{StaticResource RadiusTabbar}"
                    BorderBrush="{DynamicResource ColorWindowBorder}" BorderThickness="{StaticResource BorderTabbar}">
                <Grid>
                    <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                        Content="&#128266; Output"
                        Style="{StaticResource TabButton}"
                        Background="{Binding IsOutputTabSelected, Converter={StaticResource TabActiveBrush}}"
                        Foreground="{Binding IsOutputTabSelected, Converter={StaticResource TabActiveFgBrush}}"
                        Click="TabOutput_Click"/>

                    <Button Grid.Column="1"
                        Content="&#127908; Input"
                        Style="{StaticResource TabButton}"
                        Background="{Binding IsInputTabSelected, Converter={StaticResource TabActiveBrush}}"
                        Foreground="{Binding IsInputTabSelected, Converter={StaticResource TabActiveFgBrush}}"
                        Click="TabInput_Click"/>

                    <Button Grid.Column="2"
                        Content="&#128230; Unused"
                        Style="{StaticResource TabButton}"
                        Background="{Binding IsUnusedTabSelected, Converter={StaticResource TabActiveBrush}}"
                        Foreground="{Binding IsUnusedTabSelected, Converter={StaticResource TabActiveFgBrush}}"
                        Click="TabUnused_Click"/>

                    <Button Grid.Column="3"
                        Style="{StaticResource TabButton}"
                        Background="{Binding IsInfoTabSelected, Converter={StaticResource TabActiveBrush}}"
                        Foreground="{Binding IsInfoTabSelected, Converter={StaticResource TabActiveFgBrush}}"
                        Click="TabInfo_Click">
                    <fa:IconBlock Icon="InfoCircle" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>

